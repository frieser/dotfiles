{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
  "sisyphus_agent": {
    "disabled": false,
    "default_builder_enabled": false,
    "planner_enabled": true,
    "replace_plan": true
  },
  "git_master": {
    "commit_footer": true,
    "include_co_authored_by": true
  },
  "agents": {
    "Sisyphus": {
      "model": "google/antigravity-gemini-3-pro-high",
      "prompt_append": "NEVER report a task as finished based on assumptions. You are responsible for ensuring the final result is correct. Do not ask the user to 'check it'—YOU must be the one to verify it. Analyze the context and find the most reliable way to prove the work is done (run tests, execute code, check logs, browse the URL, run diagnostics, etc.). Your final response must include evidence of successful verification. Additionally, if you encounter any significant discovery or key fact about the project, you MUST record it in the knowledge graph memory using the available memory MCP tools.",
      "permission": {
        "bash": {
          "git commit": "ask",
          "git push": "deny"
        }
      }
    },
    "hephaestus": {
      "model": "google/antigravity-gemini-3-pro-high",
      "prompt_append": "You must be obsessed with self-verification. A task is not finished until you have proven it works. You must 'find a way' (buscarse la vida) to verify your results using any means necessary: writing test scripts, running builds, executing CLI commands, or checking side effects. Never assume success; prove it. Include your verification process and evidence in your final summary. Additionally, if you encounter any significant discovery or key fact about the project, you MUST record it in the knowledge graph memory using the available memory MCP tools.",
      "permission": {
        "bash": {
          "git commit": "ask",
          "git push": "deny"
        }
      }
    },
    "atlas": {
      "model": "google/antigravity-gemini-3-flash",
      "permission": {
        "bash": {
          "git commit": "ask",
          "git push": "deny"
        }
